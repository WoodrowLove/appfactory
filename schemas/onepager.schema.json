{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AppFactory One-Pager",
  "type": "object",
  "required": ["app_name", "tagline", "category", "target_user", "features", "screens", "monetization", "differentiation", "technical", "app_store"],
  "properties": {
    "app_name": { "type": "string", "maxLength": 30 },
    "tagline": { "type": "string", "maxLength": 100 },
    "category": { "type": "string" },
    "target_user": {
      "type": "object",
      "required": ["persona", "pain_points"],
      "properties": {
        "persona": { "type": "string" },
        "pain_points": { "type": "array", "items": { "type": "string" } },
        "current_solutions": { "type": "array", "items": { "type": "string" } },
        "why_they_fail": { "type": "array", "items": { "type": "string" } }
      }
    },
    "features": {
      "type": "object",
      "required": ["core", "premium"],
      "properties": {
        "core": { "type": "array", "items": { "type": "string" }, "minItems": 2 },
        "premium": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "deferred": { "type": "array", "items": { "type": "string" } }
      }
    },
    "screens": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "purpose"],
        "properties": {
          "name": { "type": "string" },
          "purpose": { "type": "string" },
          "copy": { "type": "string" },
          "elements": { "type": "array", "items": { "type": "string" } }
        }
      },
      "minItems": 5
    },
    "monetization": {
      "type": "object",
      "required": ["model", "price"],
      "properties": {
        "model": { "type": "string", "enum": ["freemium_subscription", "one_time_purchase", "consumable_iap"] },
        "free_tier": { "type": "string" },
        "premium_tier": { "type": "string" },
        "price": { "type": "string" },
        "annual_price": { "type": "string" },
        "lifetime_price": { "type": ["string", "null"], "description": "Optional lifetime purchase option (e.g. '$79.99')" },
        "trial": { "type": "string" },
        "rationale": { "type": "string" },
        "paywall_strategy": {
          "type": "string",
          "enum": ["onboarding_only", "contextual", "hybrid"],
          "default": "hybrid",
          "description": "hybrid = onboarding paywall + contextual trigger on premium feature tap"
        },
        "pricing_experiment": {
          "type": "object",
          "description": "RevenueCat Experiments config. Activated after 500 installs.",
          "properties": {
            "enabled": { "type": "boolean", "default": true },
            "variants": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Price points to A/B test, e.g. ['$3.99', '$4.99', '$6.99']"
            },
            "min_installs_to_activate": { "type": "integer", "default": 500 }
          }
        },
        "regional_pricing": {
          "type": "boolean",
          "default": true,
          "description": "Use App Store Connect alternate tier pricing for emerging markets"
        }
      }
    },
    "differentiation": {
      "type": "object",
      "required": ["vs_competitors", "vs_our_catalog", "unique_angle"],
      "properties": {
        "vs_competitors": { "type": "string" },
        "vs_our_catalog": { "type": "string" },
        "unique_angle": { "type": "string" }
      }
    },
    "technical": {
      "type": "object",
      "required": ["frameworks"],
      "properties": {
        "frameworks": { "type": "array", "items": { "type": "string" } },
        "ai_integration": { "type": ["string", "null"], "description": "Gemini Flash feature description, or null if no AI features" },
        "data_storage": { "type": "string" },
        "min_ios": { "type": "string", "default": "17.0" },
        "estimated_complexity": { "type": "string", "enum": ["simple", "medium", "complex"] },
        "icp_integration": {
          "type": "object",
          "description": "ICP canister integration config. Null/omitted if no ICP needed.",
          "properties": {
            "enabled": { "type": "boolean", "default": false },
            "use_case": { "type": "string", "description": "What ICP is used for: audit_trail, trust_score, etc." },
            "canister_type": { "type": "string", "enum": ["audit", "trust", "custom"] }
          }
        },
        "localization": {
          "type": "object",
          "description": "Localization configuration for Day 1 multi-language support",
          "properties": {
            "primary_language": { "type": "string", "default": "en" },
            "supported_languages": {
              "type": "array",
              "items": { "type": "string" },
              "default": ["en", "es", "de", "fr", "ja"],
              "description": "Top 5 App Store markets by default"
            }
          }
        }
      }
    },
    "app_store": {
      "type": "object",
      "required": ["primary_category", "keywords", "age_rating"],
      "properties": {
        "primary_category": { "type": "string" },
        "secondary_category": { "type": "string" },
        "keywords": { "type": "array", "items": { "type": "string" } },
        "age_rating": { "type": "string", "enum": ["4+", "9+", "12+", "17+"] }
      }
    }
  }
}
