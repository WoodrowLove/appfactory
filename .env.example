# AppFactory Environment Variables
# Copy this to .env and fill in your values

# === AI Models ===

# Anthropic (Claude Opus + Sonnet)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI (GPT-5.3-Codex for code review)
OPENAI_API_KEY=sk-your-key-here

# Google AI (Gemini Flash for in-app AI, Nano Banana Pro for icons)
GOOGLE_AI_API_KEY=AIza-your-key-here

# === Apple Developer ===

# Apple Developer Team ID
APPLE_TEAM_ID=XXXXXXXXXX

# Apple Developer email
APPLE_DEVELOPER_EMAIL=your@email.com

# Git repo for Fastlane match (code signing)
MATCH_GIT_URL=git@github.com:YourUser/appfactory-certs.git

# Fastlane match passphrase
MATCH_PASSWORD=your-passphrase-here

# App Store Connect API Key (for automated uploads)
ASC_KEY_ID=XXXXXXXXXX
ASC_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ASC_KEY_PATH=./AuthKey_XXXXXXXXXX.p8

# === Analytics ===

# RevenueCat
REVENUECAT_API_KEY=appl_your-key-here
REVENUECAT_WEBHOOK_SECRET=your-secret-here

# === Research ===

# Reddit API (OAuth2)
REDDIT_CLIENT_ID=your-client-id
REDDIT_CLIENT_SECRET=your-client-secret
REDDIT_USER_AGENT=appfactory/1.0

# X / Twitter API v2
X_BEARER_TOKEN=your-bearer-token

# === Marketing ===

# Postiz (social media scheduling)
POSTIZ_API_URL=http://localhost:4200
POSTIZ_API_KEY=your-postiz-key

# === ICP (Optional) ===

# DFX network (ic for mainnet, local for development)
DFX_NETWORK=ic

# Audit canister ID
CANISTER_ID_AUDIT=xxxxx-xxxxx-xxxxx-xxxxx-xxx

# === Factory Settings ===

# Maximum concurrent projects (default: 5)
MAX_ACTIVE_PROJECTS=5

# Maximum concurrent agent sessions (default: 3)
MAX_CONCURRENT_AGENTS=3

# Monthly API budget in USD (alerts at 80%, stops at 100%)
MONTHLY_BUDGET_USD=500

# Control Panel port
CONTROL_PANEL_PORT=5173
